<UserControl x:Class="DLVoiceLibrary.Views.PlayerBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DLVoiceLibrary.ViewModels"
             xmlns:conv="clr-namespace:DLVoiceLibrary.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PlayerBarViewModel}"
             d:DesignWidth="1280">
    <UserControl.Resources>
        <conv:PathToImageConverter x:Key="PathToImageConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:DurationToStringConverter x:Key="DurationToStringConverter" />
        <conv:RepeatModeToStringConverter x:Key="RepeatModeToStringConverter" />
        <conv:PlayPauseIconConverter x:Key="PlayPauseIconConverter" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <conv:BoolToStarConverter x:Key="BoolToStarConverter" />
    </UserControl.Resources>

    <Border Background="{StaticResource CrustBrush}" BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="0,1,0,0" Padding="10,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- 左: サムネ + 曲名/作品名 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="44" Height="44" CornerRadius="4" Background="{StaticResource Surface0Brush}"
                        ClipToBounds="True" Margin="0,0,10,0">
                    <Grid>
                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImageConverter}}"
                               Stretch="UniformToFill"
                               Visibility="{Binding ThumbnailPath, Converter={StaticResource NullToVisibilityConverter}}" />
                        <TextBlock Text="🎧" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding ThumbnailPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}" />
                    </Grid>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTrack.Title}" FontWeight="SemiBold" FontSize="12"
                               TextTrimming="CharacterEllipsis" MaxWidth="170" />
                    <TextBlock Text="{Binding CurrentWorkTitle}" Foreground="{StaticResource SubtextBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="170" />
                </StackPanel>
            </StackPanel>

            <!-- 中央: 再生コントロール + シークバー -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <Button Content="⏮" Width="34" Command="{Binding PreviousCommand}" />
                    <Button Content="{Binding IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                            Width="40" Margin="6,0" Command="{Binding TogglePlayPauseCommand}" />
                    <Button Content="⏭" Width="34" Command="{Binding NextCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Position, Converter={StaticResource DurationToStringConverter}}"
                               Width="42" TextAlignment="Right" FontSize="11" Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Center" />
                    <Slider x:Name="SeekSlider" Minimum="0" Maximum="{Binding Duration.TotalSeconds}"
                            Width="Auto" MinWidth="300" VerticalAlignment="Center" Margin="6,0"
                            PreviewMouseDown="OnSeekSliderPreviewMouseDown" PreviewMouseUp="OnSeekSliderPreviewMouseUp" />
                    <TextBlock Text="{Binding Duration, Converter={StaticResource DurationToStringConverter}}"
                               Width="42" FontSize="11" Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- 右: お気に入り/スリープタイマー/リピート/シャッフル/音量/速度 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="{Binding IsCurrentTrackFavorite, Converter={StaticResource BoolToStarConverter}}"
                        Command="{Binding ToggleCurrentTrackFavoriteCommand}" Margin="0,0,6,0" Padding="8,4" />
                <Button Content="⏰" Margin="0,0,6,0" Padding="8,4" Click="OnSleepTimerClick"
                        Opacity="{Binding SleepAtTrackEnd, Converter={StaticResource BoolToOpacityConverter}}"
                        ToolTip="{Binding SleepTimerRemaining, StringFormat='スリープタイマー残り: {0}'}" />
                <Button Content="{Binding RepeatMode, Converter={StaticResource RepeatModeToStringConverter}}"
                        Command="{Binding ToggleRepeatCommand}" Margin="0,0,6,0" Padding="6,4" />
                <Button Content="🔀" Command="{Binding ToggleShuffleCommand}" Margin="0,0,10,0" Padding="8,4"
                        Opacity="{Binding ShuffleOn, Converter={StaticResource BoolToOpacityConverter}}" />
                <ComboBox SelectedValue="{Binding PlaybackRate}" SelectedValuePath="Tag" Width="60" Margin="0,0,10,0">
                    <ComboBoxItem Content="0.75x"><ComboBoxItem.Tag><sys:Double>0.75</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1.0x"><ComboBoxItem.Tag><sys:Double>1.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1.25x"><ComboBoxItem.Tag><sys:Double>1.25</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1.5x"><ComboBoxItem.Tag><sys:Double>1.5</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="2.0x"><ComboBoxItem.Tag><sys:Double>2.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                </ComboBox>
                <TextBlock Text="🔈" VerticalAlignment="Center" Margin="0,0,4,0" />
                <Slider Value="{Binding Volume}" Minimum="0" Maximum="1" Width="90" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
