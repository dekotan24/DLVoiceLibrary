<Window x:Class="DLVoiceLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DLVoiceLibrary"
        xmlns:vm="clr-namespace:DLVoiceLibrary.ViewModels"
        xmlns:models="clr-namespace:DLVoiceLibrary.Core.Models;assembly=DLVoiceLibrary.Core"
        xmlns:conv="clr-namespace:DLVoiceLibrary.Converters"
        xmlns:views="clr-namespace:DLVoiceLibrary.Views"
        xmlns:wtk="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="DLVoiceLibrary" Height="820" Width="1280"
        Style="{StaticResource {x:Type Window}}"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImageConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:DurationToStringConverter x:Key="DurationToStringConverter" />
        <conv:EnumEqualsVisibilityConverter x:Key="EnumEqualsVisibilityConverter" />
        <conv:BoolToStarConverter x:Key="BoolToStarConverter" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <conv:BoolToPauseResumeConverter x:Key="BoolToPauseResumeConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:NotEmptyToBoolConverter x:Key="NotEmptyToBoolConverter" />

        <!-- サムネイルのホバー拡大表示(カードと詳細パネルで共用) -->
        <ToolTip x:Key="ThumbnailZoomToolTip" x:Shared="False"
                 Background="{StaticResource CrustBrush}" Padding="4"
                 ToolTipService.InitialShowDelay="350">
            <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=0}"
                   MaxWidth="520" MaxHeight="520" Stretch="Uniform" />
        </ToolTip>

        <DataTemplate x:Key="WorkCardTemplate" DataType="{x:Type models:VoiceWork}">
            <Border Width="200" Margin="6" Padding="8" Background="{StaticResource Surface0Brush}"
                    BorderBrush="{StaticResource Surface1Brush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border Height="140" CornerRadius="4" Background="{StaticResource MantleBrush}" ClipToBounds="True"
                            ToolTip="{StaticResource ThumbnailZoomToolTip}"
                            ToolTipService.IsEnabled="{Binding ThumbnailPath, Converter={StaticResource NotEmptyToBoolConverter}}"
                            ToolTipService.InitialShowDelay="350">
                        <Grid>
                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImageConverter}}"
                                   Stretch="UniformToFill"
                                   Visibility="{Binding ThumbnailPath, Converter={StaticResource NullToVisibilityConverter}}" />
                            <TextBlock Text="🎧" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource OverlayBrush}"
                                       Visibility="{Binding ThumbnailPath, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}" />
                            <Button Content="{Binding IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                    FontSize="16" Padding="6,2" Background="#66000000" BorderThickness="0"
                                    Foreground="{StaticResource YellowBrush}"
                                    ToolTip="作品をお気に入りに追加/解除"
                                    Command="{Binding DataContext.Library.ToggleWorkFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" Margin="0,8,0,2" FontWeight="SemiBold"
                               MaxHeight="42" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding CircleName}" Foreground="{StaticResource SubtextBrush}" FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ContextMenuはStackPanel(ヘッダー内容)ではなくTreeViewItem自体に付ける(Shift+F10でも開けるように)。
             Style Setter内に直接MenuItem+Clickを書くとXAMLコンパイラのconnectionIdが壊れて
             実行時XamlParseExceptionになるため、リソースとして定義してStyleからは参照だけする。 -->
        <ContextMenu x:Key="TrackContextMenu" x:Shared="False"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="プレイリストに追加..." Click="OnAddToPlaylistClick" />
        </ContextMenu>

        <Style x:Key="TrackTreeItemStyle" TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="ContextMenu" Value="{StaticResource TrackContextMenu}" />
        </Style>

        <!-- 詳細パネルのクリックフィルタリンク(サークル/声優/タグ)。ホバーで青+アンダーライン(DLGameManagerと同じ挙動)。
             Foregroundをローカル属性で指定するとトリガーが効かない(依存プロパティ優先度)ため、ベース色もスタイル側で持つ。 -->
        <Style x:Key="DetailLinkStyle" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
            <Setter Property="TextDecorations" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BlueBrush}" />
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DetailTagLinkStyle" TargetType="Hyperlink" BasedOn="{StaticResource DetailLinkStyle}">
            <Setter Property="Foreground" Value="{StaticResource OverlayBrush}" />
        </Style>

        <HierarchicalDataTemplate x:Key="TrackTreeTemplate" DataType="{x:Type models:TrackTreeNode}"
                                   ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,2"
                        Background="Transparent" ToolTip="{Binding Name}">
                <TextBlock Text="📁" Margin="0,0,6,0" Visibility="{Binding IsTrack, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                <TextBlock Text="🎵" Margin="0,0,6,0" Visibility="{Binding IsTrack, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Track.Duration, Converter={StaticResource DurationToStringConverter}}"
                           Margin="10,0,0,0" Foreground="{StaticResource SubtextBrush}" FontSize="11"
                           VerticalAlignment="Center" />
                <Button Content="{Binding Track.IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                        Visibility="{Binding IsTrack, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="6,0,0,0" Padding="4,0" Background="Transparent" BorderThickness="0"
                        Command="{Binding DataContext.Library.ToggleTrackFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding Track}" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="PlaylistTrackRowTemplate" DataType="{x:Type models:Track}">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding WorkTitle}" Foreground="{StaticResource SubtextBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Duration, Converter={StaticResource DurationToStringConverter}}"
                           Foreground="{StaticResource SubtextBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0" />
                <Button Grid.Column="2" Content="▲" Width="26" Margin="2,0"
                        Command="{Binding DataContext.Playlists.MoveTrackUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}" />
                <Button Grid.Column="3" Content="▼" Width="26" Margin="2,0"
                        Command="{Binding DataContext.Playlists.MoveTrackDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}" />
                <Button Grid.Column="4" Content="✕" Width="26" Margin="2,0"
                        Command="{Binding DataContext.Playlists.RemoveTrackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- タブ切替 -->
        <DockPanel Grid.Row="0" Margin="10,10,10,0">
            <Button DockPanel.Dock="Right" Content="⚙ 設定" Padding="12,6" Click="OnSettingsClick" />
            <StackPanel Orientation="Horizontal">
                <Button Content="📚 ライブラリ" Padding="12,6" Margin="0,0,6,0" Command="{Binding ShowLibraryTabCommand}" />
                <Button Content="📋 プレイリスト" Padding="12,6" Margin="0,0,6,0" Command="{Binding ShowPlaylistsTabCommand}" />
                <Button Content="🌐 ブラウザ" Padding="12,6" Command="{Binding ShowBrowserTabCommand}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <!-- ライブラリタブ -->
            <Grid Visibility="{Binding CurrentTab, Converter={StaticResource EnumEqualsVisibilityConverter}, ConverterParameter=Library}"
                  AllowDrop="True" Drop="OnLibraryDrop" DragOver="OnLibraryDragOver">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="10" LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="🕐 最近再生" Margin="6,0,0,0" Padding="12,6"
                            Click="OnRecentlyPlayedClick" />
                    <Button DockPanel.Dock="Right" Content="👁 監視設定" Margin="6,0,0,0" Padding="12,6"
                            Click="OnWatchFoldersClick" />
                    <Button DockPanel.Dock="Right" Content="📁 一括追加" Margin="6,0,0,0" Padding="12,6"
                            Command="{Binding Library.AddParentFolderCommand}" />
                    <Button DockPanel.Dock="Right" Content="＋ 作品追加" Margin="6,0,0,0" Padding="12,6"
                            Command="{Binding Library.AddFolderCommand}" />
                    <ToggleButton DockPanel.Dock="Right" Content="🔧 詳細検索" Margin="6,0,0,0" Padding="12,6"
                                  IsChecked="{Binding Library.IsAdvancedSearchOpen}" />
                    <ToggleButton DockPanel.Dock="Right" Content="★ お気に入り" Margin="6,0,0,0" Padding="12,6"
                                  ToolTip="お気に入りに登録した作品だけを表示"
                                  IsChecked="{Binding Library.FavoritesOnly}" />
                    <TextBox x:Name="SearchBox"
                             Text="{Binding Library.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Tag="🔍 タイトル / サークル / 声優 / タグ / RJ番号で検索 (Ctrl+F)" />
                </DockPanel>

                <!-- 詳細検索パネル -->
                <Border Grid.Row="1" Margin="10,0,10,8" Padding="12,8"
                        Background="{StaticResource MantleBrush}" CornerRadius="6"
                        Visibility="{Binding Library.IsAdvancedSearchOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="サークル:" VerticalAlignment="Center" Margin="0,0,6,6" />
                            <ComboBox ItemsSource="{Binding Library.CircleOptions}"
                                      SelectedItem="{Binding Library.SelectedCircle}"
                                      Width="220" Height="28" Margin="0,0,16,6" />
                            <TextBlock Text="販売日:" VerticalAlignment="Center" Margin="0,0,6,6" />
                            <TextBox Text="{Binding Library.ReleaseDateFromText, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                     Width="110" Margin="0,0,4,6" Tag="2024/01/01" />
                            <TextBlock Text="～" VerticalAlignment="Center" Margin="0,0,4,6" />
                            <TextBox Text="{Binding Library.ReleaseDateToText, UpdateSourceTrigger=PropertyChanged, Delay=400}"
                                     Width="110" Margin="0,0,16,6" Tag="2026/12/31" />
                            <Button Content="条件をクリア" Padding="10,4" Margin="0,0,0,6"
                                    Command="{Binding Library.ClearAdvancedSearchCommand}" />
                        </WrapPanel>
                        <TextBlock Text="声優(選択した声優が全員出演する作品に絞り込み):"
                                   Foreground="{StaticResource SubtextBrush}" FontSize="11" Margin="0,2,0,4" />
                        <ScrollViewer MaxHeight="96" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Library.VoiceActorFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Content="{Binding Display}" IsChecked="{Binding IsSelected}"
                                                      FontSize="11" Margin="0,0,6,6" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Text="タグ(選択したタグを全て含む作品に絞り込み):"
                                   Foreground="{StaticResource SubtextBrush}" FontSize="11" Margin="0,6,0,4" />
                        <ScrollViewer MaxHeight="96" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Library.GenreFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Content="{Binding Display}" IsChecked="{Binding IsSelected}"
                                                      FontSize="11" Margin="0,0,6,6" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="10,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="WorksListBox" Grid.Column="0"
                             ItemsSource="{Binding Library.WorksView}"
                             SelectedItem="{Binding Library.SelectedWork}"
                             ItemTemplate="{StaticResource WorkCardTemplate}"
                             Background="{StaticResource BaseBrush}" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <wtk:VirtualizingWrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                                  Background="{StaticResource Surface1Brush}" />

                    <Border Grid.Column="2" Background="{StaticResource MantleBrush}" CornerRadius="6" Padding="10"
                            DataContext="{Binding Library.WorkDetail}">
                        <Grid>
                            <StackPanel Visibility="{Binding Work, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="作品を選択するとトラック一覧が表示されます" Foreground="{StaticResource SubtextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <DockPanel Visibility="{Binding Work, Converter={StaticResource NullToVisibilityConverter}}">
                                <Border DockPanel.Dock="Top" MaxHeight="180" CornerRadius="4" Margin="0,0,0,8"
                                        Background="{StaticResource CrustBrush}" ClipToBounds="True"
                                        DataContext="{Binding Work}"
                                        ToolTip="{StaticResource ThumbnailZoomToolTip}"
                                        ToolTipService.IsEnabled="{Binding ThumbnailPath, Converter={StaticResource NotEmptyToBoolConverter}}"
                                        ToolTipService.InitialShowDelay="350"
                                        Visibility="{Binding ThumbnailPath, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=0}"
                                           Stretch="Uniform" />
                                </Border>
                                <TextBlock DockPanel.Dock="Top" Text="{Binding Work.Title}" FontWeight="Bold" FontSize="14"
                                           TextWrapping="Wrap" Margin="0,0,0,4" />
                                <!-- サークル名クリックでそのサークルに絞り込み -->
                                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,2"
                                           Visibility="{Binding Work.CircleName, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Hyperlink Style="{StaticResource DetailLinkStyle}"
                                               ToolTip="このサークルの作品に絞り込む"
                                               Command="{Binding DataContext.Library.FilterByCircleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding Work.CircleName}">
                                        <Run Text="{Binding Work.CircleName, Mode=OneWay}" />
                                    </Hyperlink>
                                </TextBlock>
                                <!-- 声優名クリックでその声優に絞り込み -->
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,2"
                                           Visibility="{Binding Work.VoiceActors, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="CV: " Foreground="{StaticResource SubtextBrush}" FontSize="11" />
                                    <ItemsControl ItemsSource="{Binding Work.VoiceActorList}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="11" Margin="0,0,8,0">
                                                    <Hyperlink Style="{StaticResource DetailLinkStyle}"
                                                               ToolTip="この声優の出演作品に絞り込む"
                                                               Command="{Binding DataContext.Library.FilterByVoiceActorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               CommandParameter="{Binding}">
                                                        <Run Text="{Binding Mode=OneWay}" />
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </WrapPanel>
                                <!-- タグクリックでそのタグに絞り込み -->
                                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Work.GenreTagList}" Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontSize="11" Margin="0,0,8,2">
                                                <Hyperlink Style="{StaticResource DetailTagLinkStyle}"
                                                           ToolTip="このタグの作品に絞り込む"
                                                           Command="{Binding DataContext.Library.FilterByTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           CommandParameter="{Binding}">
                                                    <Run Text="{Binding Mode=OneWay}" />
                                                </Hyperlink>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <Button Content="▶ 全曲再生" Padding="10,4" Margin="0,0,6,6" Click="OnPlayAllClick" />
                                    <Button Content="{Binding Work.IsFavorite, Converter={StaticResource BoolToStarConverter}}"
                                            Padding="10,4" Margin="0,0,6,6" Foreground="{StaticResource YellowBrush}"
                                            ToolTip="作品をお気に入りに追加/解除"
                                            Command="{Binding DataContext.Library.ToggleWorkFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Work}" />
                                    <Button Content="🔄 再取得" Padding="10,4" Margin="0,0,6,6"
                                            Command="{Binding DataContext.Library.RefetchMetadataCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    <Button Content="📂 フォルダを開く" Padding="10,4" Margin="0,0,6,6"
                                            Click="OnOpenInExplorerClick" />
                                    <Button Content="🌐 DLsiteで開く" Padding="10,4" Margin="0,0,6,6"
                                            Click="OnOpenInBrowserClick"
                                            Visibility="{Binding Work.ProductId, Converter={StaticResource NullToVisibilityConverter}}" />
                                    <Button Content="⚙ プロパティ" Padding="10,4" Margin="0,0,6,6"
                                            Click="OnPropertiesClick" />
                                    <Button Content="🗑 一覧から削除" Padding="10,4" Margin="0,0,6,6"
                                            ToolTip="ライブラリの一覧から取り除きます。ディスク上のファイルは削除されません。監視フォルダによる自動再登録もされなくなります(手動追加すれば戻せます)。"
                                            Click="OnDeleteWorkClick" />
                                </WrapPanel>
                                <TreeView ItemsSource="{Binding TrackTree}" ItemTemplate="{StaticResource TrackTreeTemplate}"
                                          ItemContainerStyle="{StaticResource TrackTreeItemStyle}"
                                          Background="Transparent" BorderThickness="0"
                                          MouseDoubleClick="OnTrackTreeDoubleClick" />
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- プレイリストタブ -->
            <Grid Visibility="{Binding CurrentTab, Converter={StaticResource EnumEqualsVisibilityConverter}, ConverterParameter=Playlists}"
                  Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="＋ 新規作成" Padding="10,5" Margin="0,0,6,0" Click="OnCreatePlaylistClick" />
                        <Button Content="削除" Padding="10,5" Command="{Binding Playlists.DeleteSelectedPlaylistCommand}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Playlists.Playlists}"
                             SelectedItem="{Binding Playlists.SelectedPlaylist}"
                             DisplayMemberPath="Name"
                             Background="{StaticResource MantleBrush}" BorderThickness="0" />
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                              Background="{StaticResource Surface1Brush}" />

                <DockPanel Grid.Column="2" Margin="10,0,0,0" DataContext="{Binding Playlists}">
                    <StackPanel DockPanel.Dock="Top" Visibility="{Binding SelectedPlaylist, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding SelectedPlaylist.Name}" FontWeight="Bold" FontSize="16" Margin="0,0,0,8" />
                        <Button Content="▶ 全曲再生" HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,10"
                                Click="OnPlayPlaylistClick" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="プレイリストを選択してください"
                               Foreground="{StaticResource SubtextBrush}"
                               Visibility="{Binding SelectedPlaylist, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}" />
                    <ListBox ItemsSource="{Binding SelectedPlaylistTracks}"
                             ItemTemplate="{StaticResource PlaylistTrackRowTemplate}"
                             Background="{StaticResource BaseBrush}" BorderThickness="0"
                             MouseDoubleClick="OnPlaylistTrackDoubleClick" />
                </DockPanel>
            </Grid>

            <!-- ブラウザタブ -->
            <Grid Visibility="{Binding CurrentTab, Converter={StaticResource EnumEqualsVisibilityConverter}, ConverterParameter=Browser}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="10" LastChildFill="True">
                    <Button DockPanel.Dock="Left" Content="←" Width="34" Margin="0,0,4,0" Click="OnBrowserBackClick" />
                    <Button DockPanel.Dock="Left" Content="→" Width="34" Margin="0,0,4,0" Click="OnBrowserForwardClick" />
                    <Button DockPanel.Dock="Left" Content="⟳" Width="34" Margin="0,0,6,0" Click="OnBrowserReloadClick" />
                    <TextBox x:Name="BrowserUrlBox" VerticalContentAlignment="Center"
                             Tag="URLを入力してEnter" KeyDown="OnBrowserUrlKeyDown" />
                </DockPanel>

                <wv2:WebView2 x:Name="Browser" Grid.Row="1" />
            </Grid>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="{StaticResource CrustBrush}" Padding="10,6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            Visibility="{Binding Library.MetadataQueueCount, Converter={StaticResource CountToVisibilityConverter}}">
                    <TextBlock Text="{Binding Library.MetadataQueueCount, StringFormat='メタデータ取得待ち: {0}件'}"
                               Foreground="{StaticResource SubtextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="{Binding Library.MetadataFetchPaused, Converter={StaticResource BoolToPauseResumeConverter}}"
                            Command="{Binding Library.ToggleMetadataFetchPauseCommand}" Padding="8,2" FontSize="11" />
                </StackPanel>
                <TextBlock Text="{Binding Library.StatusMessage}" Foreground="{StaticResource SubtextBrush}" FontSize="12" />
            </DockPanel>
        </Border>

        <!-- 下部固定ミニプレーヤー -->
        <views:PlayerBar Grid.Row="3" DataContext="{Binding Player}" />
